# Revenium API Configuration (required for all CLIs)
REVENIUM_API_KEY=hak_your_revenium_api_key
REVENIUM_ENDPOINT=https://api.revenium.ai

# User Attribution (optional)
REVENIUM_EMAIL=developer@company.com
REVENIUM_ORGANIZATION_NAME=my-org
REVENIUM_PRODUCT_NAME=my-product

# Cursor IDE Configuration
CURSOR_API_KEY=your-cursor-admin-api-key
CURSOR_SUBSCRIPTION_TIER=business
REVENIUM_SYNC_INTERVAL_MS=300000

# Cost Configuration (optional)
# Overrides the tier-based multiplier
# Range: 0 to 1 (e.g., 0.08 = 92% discount)
REVENIUM_COST_MULTIPLIER=1.0
