{
  "name": "@revenium/cli",
  "version": "1.0.0",
  "description": "Unified Revenium CLI tools for Claude Code, Gemini CLI, and Cursor metering setup",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "revenium-metering": "./dist/claude-code/cli/index.js",
    "revenium-gemini": "./dist/gemini-cli/cli/index.js",
    "revenium-cursor": "./dist/cursor/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"const fs = require('fs'); if (fs.existsSync('dist')) fs.rmSync('dist', {recursive: true, force: true})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:core": "vitest run tests/unit/_core",
    "test:cursor": "vitest run tests/unit/cursor",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "revenium",
    "cli",
    "claude-code",
    "gemini",
    "cursor",
    "metering",
    "telemetry"
  ],
  "author": "Revenium",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revenium/revenium-cli-node.git"
  },
  "homepage": "https://github.com/revenium/revenium-cli-node#readme",
  "bugs": {
    "url": "https://github.com/revenium/revenium-cli-node/issues"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "inquirer": "^12.6.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
