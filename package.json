{
  "name": "@revenium/cli",
  "version": "1.0.6",
  "description": "Unified Revenium CLI tools for Claude Code, Gemini CLI, and Cursor metering setup",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "revenium-metering": "./dist/claude-code/cli/index.js",
    "revenium-gemini": "./dist/gemini-cli/cli/index.js",
    "revenium-cursor": "./dist/cursor/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"const fs = require('fs'); if (fs.existsSync('dist')) fs.rmSync('dist', {recursive: true, force: true})\"",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:core": "vitest run tests/unit/_core",
    "test:cursor": "vitest run tests/unit/cursor",
    "test:schema": "vitest run tests/unit/_core/otlp-schema.test.ts",
    "test:e2e": "vitest run tests/integration/e2e.test.ts",
    "test:integration": "vitest run tests/integration",
    "test:provider-e2e": "vitest run tests/integration/provider-e2e.test.ts --testTimeout=120000",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [
    "revenium",
    "cli",
    "claude-code",
    "gemini",
    "cursor",
    "metering",
    "telemetry"
  ],
  "author": "Revenium",
  "license": "MIT",
  "homepage": "https://github.com/revenium/revenium-cli-node#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/revenium/revenium-cli-node.git"
  },
  "bugs": {
    "url": "https://github.com/revenium/revenium-cli-node/issues"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^17.4.0",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist/**/*",
    "!dist/**/*.map"
  ],
  "engines": {
    "node": ">=20.19.0"
  }
}
